PORT=3000
HOST=0.0.0.0
SESSION_SECRET=cambia-esta-clave-por-una-larga-y-privada
DB_PATH=./data/restaurant.db
CORS_ORIGINS=
NODE_ENV=development
COOKIE_SECURE=false

# PWA / HTTPS local opcional
# La instalación PWA funciona en PC con http://localhost o http://127.0.0.1.
# Para instalar desde móvil usando la IP local de la PC se requiere HTTPS con certificado confiable.
HTTPS_ENABLED=false
HTTPS_KEY_PATH=./certs/localhost-key.pem
HTTPS_CERT_PATH=./certs/localhost.pem
