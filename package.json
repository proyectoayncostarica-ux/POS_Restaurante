{
  "name": "mundipos",
  "version": "3.1.2",
  "description": "MundiPOS - sistema POS local para restaurante/bar",
  "main": "server/app.js",
  "scripts": {
    "start": "node server/app.js",
    "dev": "nodemon server/app.js",
    "test": "node --test --test-concurrency=1",
    "test:transactions": "node --test --test-concurrency=1 tests/transactionService.test.js",
    "test:domain": "node --test --test-concurrency=1 tests/money.test.js tests/idempotency.test.js tests/baseFixture.test.js",
    "test:access": "node --test --test-concurrency=1 tests/capabilityService.test.js tests/operationalAccessService.test.js tests/operationalAccessParity.test.js",
    "test:accounts": "node --test --test-concurrency=1 tests/accountService.test.js tests/globalAccountMigration.test.js tests/consumptionLineMigration.test.js",
    "test:lines": "node --test --test-concurrency=1 tests/consumptionLines.test.js tests/consumptionLineMigration.test.js",
    "test:prefacturas": "node --test --test-concurrency=1 tests/documentSequence.test.js tests/preinvoiceService.test.js tests/preinvoiceMigration.test.js"
  },
  "keywords": [
    "restaurant",
    "management",
    "pos",
    "nodejs",
    "express",
    "sqlite"
  ],
  "author": "Manus AI",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.3",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "multer": "^1.4.5-lts.1",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "nodemon": "^3.1.10"
  }
}
